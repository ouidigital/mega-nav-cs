<header id="cs-navigation">

	<!-- Optional top bar (hardcoded — edit directly if you need it).
	     Remove this block if your layout doesn't include a top bar. -->
	<div class="cs-top-bar">
		<div class="cs-top-container">
			<div class="cs-top-contact">
				<a href="tel:+1234567890" class="cs-top-link">
					<svg class="cs-icon" aria-hidden="true"><use href="#icon-phone"/></svg>
					Call us: +1 (234) 567-890
				</a>
				<a href="mailto:hello@example.com" class="cs-top-link">
					<svg class="cs-icon" aria-hidden="true"><use href="#icon-clock"/></svg>
					Mon – Sat: 8:00am – 9:00pm
				</a>
			</div>
			<div class="cs-top-social">
				<a href="#" class="cs-social-link" aria-label="Message us">
					<svg class="cs-icon" aria-hidden="true"><use href="#icon-message"/></svg>
				</a>
				<a href="#" class="cs-social-link" aria-label="Email us">
					<svg class="cs-icon" aria-hidden="true"><use href="#icon-envelope"/></svg>
				</a>
			</div>
		</div>
	</div>

	<div class="cs-container">
		<!-- Nav Logo -->
		<a href="/" class="cs-logo" aria-label="Return to [Company Name] home page">
			<img src="/assets/svgs/logo-black.svg" alt="" width="210" height="29" aria-hidden="true" decoding="async" />
		</a>

		<!-- Navigation List -->
		<nav class="cs-nav" aria-label="main navigation">
			<!-- Mobile Nav Toggle -->
			<button class="cs-toggle" id="cs-toggle" aria-expanded="false" aria-controls="cs-ul-wrapper" aria-haspopup="menu" aria-label="mobile menu toggle">
				<span class="cs-box" aria-hidden="true">
					<span class="cs-line cs-line1" aria-hidden="true"></span>
					<span class="cs-line cs-line2" aria-hidden="true"></span>
					<span class="cs-line cs-line3" aria-hidden="true"></span>
				</span>
			</button>

			<!-- Drawer wrapper (mobile sliding panel / desktop pass-through) -->
			<div class="cs-ul-wrapper" id="cs-ul-wrapper">
				<ul id="cs-expanded" class="cs-ul">
					{navData.map((item) => {
						/* -------- Simple link -------- */
						if (!isDropdown(item)) {
							return (
								<li class="cs-li">
									<a
										href={item.url}
										class:list={["cs-li-link", { "cs-active": isCurrentPage(item.url) }]}
										aria-current={isCurrentPage(item.url) ? "page" : undefined}>
										{item.key}
									</a>
								</li>
							);
						}

						/* -------- Dropdown (standard or mega) -------- */
						const panelId = getDropdownId(item.key);
						const toggleId = getToggleId(item.key);
						const active = isDropdownActive(item);
						const mega = isMega(item);
						const rightAligned = item.align === "right";

						return (
							<li class:list={["cs-li", "cs-dropdown", { "cs-mega": mega }]}>
								<button
									class:list={["cs-li-link cs-dropdown-button", { "cs-active": active }]}
									type="button"
									aria-haspopup="true"
									aria-expanded="false"
									aria-controls={panelId}
									id={toggleId}>
									{item.key}
									<svg class="cs-drop-icon" aria-hidden="true"><use href="#icon-arrow-down"/></svg>
								</button>

								<div
									class:list={[
										"cs-drop-panel",
										mega && item.panelClass ? item.panelClass : null,
										{ "cs-drop-right": rightAligned },
									]}
									id={panelId}
									aria-labelledby={toggleId}>
									<div class="cs-drop-inner">
										{mega ? (
											<div class="cs-mega-grid">
												{item.categories.map((cat) => (
													<div class="cs-mega-category">
														{cat.title && <h3 class="cs-mega-category-title">{cat.title}</h3>}
														<ul class="cs-drop-ul">
															{(cat.links || []).map((link) => (
																<li class="cs-drop-li">
																	<a href={link.url} class="cs-li-link cs-drop-link">
																		{link.icon && (
																			<svg class="cs-icon" aria-hidden="true"><use href={`#icon-${link.icon}`}/></svg>
																		)}
																		{" "}{link.key}
																	</a>
																</li>
															))}
														</ul>
													</div>
												))}

												{item.promo && (
													<div class="cs-mega-promo">
														{item.promo.title && <h4 class="cs-mega-promo-title">{item.promo.title}</h4>}
														{item.promo.text && <p class="cs-mega-promo-text">{item.promo.text}</p>}
														{item.promo.btnUrl && (
															<a href={item.promo.btnUrl} class="cs-mega-promo-btn">
																{item.promo.btnLabel}
																{item.promo.btnIcon && (
																	<svg class="cs-icon" aria-hidden="true" style="width:0.875em;height:0.875em;">
																		<use href={`#icon-${item.promo.btnIcon}`}/>
																	</svg>
																)}
															</a>
														)}
													</div>
												)}
											</div>
										) : (
											<ul class="cs-drop-ul">
												{item.children.map((child) => (
													<li class="cs-drop-li">
														<a href={child.url} class="cs-li-link cs-drop-link">
															{child.icon && (
																<svg class="cs-icon" aria-hidden="true"><use href={`#icon-${child.icon}`}/></svg>
															)}
															{" "}{child.key}
														</a>
													</li>
												))}
											</ul>
										)}
									</div>
								</div>
							</li>
						);
					})}
				</ul>
			</div>
		</nav>

		<!-- CTA button (reuses CS .cs-button-solid) -->
		<a href="/contact/" class="cs-button-solid cs-nav-button">Contact Us</a>

		<!-- Dark Mode toggle: remove component if you don't want dark mode -->
		<DarkModeToggle />
	</div>
</header>

<!-- Click-only disclosure controller (place mega-menu.js next to this file) -->
<script>
	import "./mega-menu.js";
</script>

<style lang="less">
	/*-- -------------------------- -->
	<---   CodeStitch Mega Nav      -->
	<---   (click-only, mega-menu)  -->
	<--- -------------------------- -*/

	#cs-navigation {
		--cs-nav-panel-bg: #fff;
		--cs-nav-panel-shadow: rgba(149, 157, 165, 0.2) 0px 10px 16px;
		--cs-nav-panel-radius: 6px;
		--cs-nav-hover-bg: #f7f7f7;
		--cs-nav-ease: 200ms cubic-bezier(0.4, 0, 0.2, 1);
	}

	.cs-icon {
		width: 1.15em;
		height: 1.15em;
		flex-shrink: 0;
		fill: none;
		stroke: currentColor;
		stroke-width: 1.5px;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	/* Mobile */
	@media only screen and (max-width: 63.9375rem) {
		body.cs-open { overflow: hidden; }
		body.scroll #cs-navigation { transform: translateY(-3.3125rem); }

		#cs-navigation {
			width: 100%;
			box-sizing: border-box;
			background-color: #fff;
			box-shadow: rgba(149, 157, 165, 0.2) 0px 8px 24px;
			position: fixed;
			top: 0; left: 0;
			z-index: 10000;
			transition: transform 0.3s;

			&:before {
				content: "";
				width: 100%;
				height: 0vh;
				background: rgba(0, 0, 0, 0.6);
				opacity: 0;
				display: block;
				position: absolute;
				top: 100%; right: 0;
				z-index: -1100;
				transition: height 0.5s, opacity 0.5s;
				-webkit-backdrop-filter: blur(10px);
				backdrop-filter: blur(10px);
			}

			&.cs-active {
				&:before { height: 150vh; opacity: 1; }
				.cs-ul-wrapper { opacity: 1; transform: scaleY(1); transition-delay: 0.15s; }
				.cs-li { opacity: 1; transform: translateY(0); }
			}

			.cs-top-bar { width: 100%; display: flex; justify-content: center; align-items: center; }
			.cs-top-container {
				width: 100%; box-sizing: border-box;
				padding: 1rem 1.5rem;
				background-color: #f7f7f7;
				display: flex; justify-content: space-between; align-items: center; gap: 1rem;
			}
			.cs-top-contact { display: flex; align-items: center; gap: clamp(1rem, 2vw, 1.5rem); }
			.cs-top-link {
				font-size: 0.875rem; line-height: 1.5em; text-decoration: none;
				color: var(--bodyTextColor);
				display: flex; align-items: center; gap: 0.5rem;
				&:nth-of-type(2) { display: none; }
			}
			.cs-top-social { display: flex; align-items: center; gap: 0.75rem; }

			.cs-container {
				width: 100%; box-sizing: border-box;
				padding: 1.25rem 1rem;
				display: flex; justify-content: flex-end; align-items: center;
				gap: 0.75rem; position: relative;
			}

			.cs-logo {
				width: auto; height: 2.5rem;
				margin: 0 auto 0 0; padding: 0;
				display: flex; justify-content: center; align-items: center;
				order: 1; z-index: 10;
				img { width: auto; height: 100%; object-fit: contain; }
			}

			.cs-nav { order: 2; }
			.cs-nav-button { display: none; }

			.cs-toggle {
				width: 2.875rem; height: 2.875rem;
				margin: 0 0 0 auto; padding: 0;
				background-color: var(--primary);
				border: none; cursor: pointer;
				display: flex; justify-content: center; align-items: center;
				transition: transform 0.6s;
				&.cs-active { transform: rotate(180deg); }
			}
			.cs-box { width: clamp(1.5rem, 2vw, 1.75rem); height: 0.75rem; position: relative; }
			.cs-line {
				width: 100%; height: 2px;
				background-color: var(--bodyTextColorWhite); border-radius: 2px;
				position: absolute; left: 50%;
				transform: translateX(-50%);
