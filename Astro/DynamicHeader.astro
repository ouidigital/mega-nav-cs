---
/**
 * CODESTITCH MEGA NAVIGATION — Dynamic variant (Astro component)
 * ==============================================================
 *
 * Data-driven counterpart to `StaticHeader.astro`. Reads the nav
 * structure from `navData.json` and renders mega-menu markup by
 * iterating the data, so content edits happen in one JSON file
 * instead of in the component markup.
 *
 * Item shapes supported in navData.json:
 *
 *   Simple link:
 *     { "key": "Home", "url": "/" }
 *
 *   Standard dropdown:
 *     {
 *       "key": "Company",
 *       "align": "right",                      // optional — anchors panel to right edge
 *       "children": [
 *         { "key": "About Us", "url": "/about/", "icon": "building" },
 *         ...
 *       ]
 *     }
 *
 *   Mega-menu dropdown (categories + optional featured promo):
 *     {
 *       "key": "Services",
 *       "panelClass": "cs-grid-3",             // cs-grid-2 | cs-grid-3 | cs-grid-4
 *       "activePrefix": "/services/",          // matches any URL starting with this
 *       "categories": [
 *         {
 *           "title": "Professional",
 *           "links": [
 *             { "key": "Website Design", "url": "/services/web/", "icon": "layout" },
 *             ...
 *           ]
 *         }
 *       ],
 *       "promo": {
 *         "title": "Need a quote?",
 *         "text": "...",
 *         "btnLabel": "Get Estimate",
 *         "btnUrl": "/contact/",
 *         "btnIcon": "arrow-right"
 *       }
 *     }
 *
 * Icons: each `icon` string maps to a <symbol id="icon-{name}"/>
 * in the inline SVG sprite below. Add more symbols to match your
 * own menu.
 *
 * Prerequisites:
 *  - Place `mega-menu.js` next to this component.
 *  - Your starter theme should expose --primary, --headerColor,
 *    --bodyTextColor, --bodyTextColorWhite, --dark, --medium on :root.
 */

// Components
import DarkModeToggle from "@components/DarkModeToggle/DarkModeToggle.astro";

// Data
import navData from "./navData.json";

/* ------------------------------------------------------------------ */
/*  Helpers — tiny, inlined. Move to a shared `utils.js` if you like. */
/* ------------------------------------------------------------------ */

const pathname = Astro.url.pathname;

/** Simple, predictable slug for panel IDs. */
const slugify = (s) =>
	String(s)
		.toLowerCase()
		.replace(/[^a-z0-9]+/g, "-")
		.replace(/(^-|-$)/g, "");

/** Exact match for a simple link's active state. */
const isCurrentPage = (url) => url === pathname;

/** Panel/toggle IDs generated from the item key. */
const getDropdownId = (key) => `cs-panel-${slugify(key)}`;
const getToggleId = (key) => `${slugify(key)}-dropdown-toggle`;

/**
 * Resolve a dropdown's "active" state:
 *  - If `activePrefix` is provided, match pathname.startsWith(prefix).
 *  - Otherwise, active if any child URL matches the current path.
 */
const isDropdownActive = (item) => {
	if (item.activePrefix) return pathname.startsWith(item.activePrefix);
	if (Array.isArray(item.children)) {
		return item.children.some((c) => c.url === pathname);
	}
	if (Array.isArray(item.categories)) {
		return item.categories.some((cat) =>
			(cat.links || []).some((l) => l.url === pathname),
		);
	}
	return false;
};

const isMega = (item) => Array.isArray(item.categories) && item.categories.length > 0;
const isDropdown = (item) => isMega(item) || (Array.isArray(item.children) && item.children.length > 0);
---

